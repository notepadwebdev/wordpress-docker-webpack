{
    "name": "notepadwebdevelopment/boilerplate",
    "description": "WordPress project running in Docker with Composer and ACF Pro setup.",
    "type": "project",
    "require": {
        "wpengine/advanced-custom-fields-pro": "*",
        "wpackagist-plugin/wordpress-seo": "*",
        "wpackagist-plugin/duplicate-post": "*",
        "wpackagist-plugin/enable-media-replace": "*",
        "wpackagist-plugin/regenerate-thumbnails": "*",
        "wpackagist-plugin/svg-support": "*",
        "wpackagist-plugin/resizable-editor-sidebar": "*",
        "wpackagist-plugin/acf-extended": "*",
        "wpackagist-plugin/wp-migrate-db": "*"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        },
        {
          "type": "composer",
          "url": "https://connect.advancedcustomfields.com"
        }
    ],
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
